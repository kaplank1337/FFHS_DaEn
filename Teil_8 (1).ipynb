   "source": [
    "#Analyse-Ergebnise prüfen\n",
    "\n",
    "spark.sql(\"\"\"\n",
    "    SELECT\n",
    "        windowStart,\n",
    "        windowEnd,\n",
    "        walkId,\n",
    "        measurementCount,\n",
    "        avgPressureHpa,\n",
    "        minPressureHpa,\n",
    "        maxPressureHpa,\n",
    "        stddevPressureHpa\n",
    "    FROM barometer_realtime_analysis\n",
    "    ORDER BY windowStart DESC\n",
    "    LIMIT 20\n",
    "\"\"\").show(truncate=False)"
   ]
  },
